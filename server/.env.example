PORT=5000
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/iptv-platform?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d
NODE_ENV=development

# Comma-separated list of allowed client origins (add your Vercel client URL here in production)
CLIENT_URL=http://localhost:3000,http://localhost:3001

# Cloudinary (image uploads) — get these from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
